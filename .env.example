# AWS credentials
# Option 1 - IAM user: fill in all three values
# Option 2 - SSO: run 'aws sso login --profile your-profile'
#            then 'aws configure export-credentials --profile your-profile --format env'
#            paste the three exported values here, including AWS_SESSION_TOKEN

AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 - original PDF storage
S3_BUCKET_NAME=

# S3 Vectors
S3_VECTOR_BUCKET_NAME=
S3_VECTOR_INDEX_NAME=

# Bedrock models
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_GENERATION_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# RAG parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# OpenTelemetry
OTEL_SERVICE_NAME=pdf-rag-api

# Points to jaeger container name defined in docker-compose
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
GENERATION_MAX_TOKENS=1024
GENERATION_TEMPERATURE=0.0